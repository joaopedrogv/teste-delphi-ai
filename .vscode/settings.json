{
  "files.associations": {
    "*.pas": "pascal",
    "*.dpr": "pascal",
    "*.dpk": "pascal",
    "*.dfm": "pascal",
    "*.inc": "pascal",
    "*.sql": "sql"
  },
  "[pascal]": {
    "files.encoding": "iso88591"
  },
  "files.defaultLanguage": "pascal",
  "workbench.editorAssociations": {
    "*.dfm": "default"
  },
  "search.exclude": {
    "**/*.dcu": true,
    "**/*.exe": true,
    "**/*.dll": true,
    "**/.git": true
  }
}